# Single account: FIREFLIES_API_KEY=key1
# Multiple accounts: FIREFLIES_API_KEY=key1,key2,key3
FIREFLIES_API_KEY=your_fireflies_api_key
NOTION_API_KEY=your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id
OPENAI_API_KEY=your_openai_api_key
SUMMARY_PROMPT=your_system_prompt_for_chatgpt_summary
LOOKBACK_HOURS=24
# Set to 'true' to delete Fireflies transcripts after successful Notion sync
DELETE_AFTER_SYNC=false
